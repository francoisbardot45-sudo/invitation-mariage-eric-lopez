{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "hosting": {
    "public": "public",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      { "source": "/api/**", "function": "api" },
      { "source": "/gestion-eric-lopez-2026/**", "function": "api" },
      { "source": "/gestion-eric-lopez-2026", "function": "api" }
    ]
  },
  "functions": [
    {
      "source": ".",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "public",
        "data",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local",
        "render.yaml",
        "firebase-setup.txt"
      ]
    }
  ]
}
